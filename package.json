{
  "name": "bizcloser-extension",
  "version": "1.0.0",
  "description": "Chrome extension for generating high-converting SMS replies",
  "scripts": {
    "build": "webpack --mode=production",
    "dev": "webpack --mode=development --watch",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:extension-audit": "node output/playwright/extension-audit/audit_extension.js"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.268",
    "@vitest/ui": "^1.3.0",
    "copy-webpack-plugin": "^12.0.0",
    "jsdom": "^24.0.0",
    "playwright": "^1.58.2",
    "ts-loader": "^9.5.4",
    "typescript": "^5.3.0",
    "vitest": "^1.3.0",
    "webpack": "^5.90.0",
    "webpack-cli": "^5.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
